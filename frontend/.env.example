# ──────────────────────────────────────────────────────────
# Sello Verde — Frontend Environment Variables
# Copy this file to .env.local for local development.
# ──────────────────────────────────────────────────────────

# Backend API base URL (WITHOUT trailing slash, WITHOUT /api suffix).
#
# Development:
#   NEXT_PUBLIC_API_URL=http://localhost:3001
#
# Production with Nginx (reverse proxy):
#   NEXT_PUBLIC_API_URL=https://api.selloverde.cl
#
# How it is used internally:
#   - REST calls:    {NEXT_PUBLIC_API_URL}/api/...
#   - Static files:  {NEXT_PUBLIC_API_URL}/uploads/...
#
NEXT_PUBLIC_API_URL=http://localhost:3001
